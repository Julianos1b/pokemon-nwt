#ifndef MOVE_H
#define MOVE_H

class Move {
  public:
    const char* name;
    int energyCost;
    int baseDamage;

    Move() {}

    Move(const char* n, int cost, int dmg) {
      name = n;
      energyCost = cost;
      baseDamage = dmg;
    }
};

#endif

