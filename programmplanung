#include "ShiggyAttack.h"
#include <Adafruit_NeoPixel.h>

extern Adafruit_NeoPixel strip;

void ShiggyAttack::play() {
  for (int i = 0; i < 20; i++) {
    strip.setPixelColor(i, strip.Color(0, 0, 255));
    strip.show();
    delay(20);
  }
}


