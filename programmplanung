🧱 1. Basisklasse: Pokemon

📄 Pokemon.h

#ifndef POKEMON_H
#define POKEMON_H

#include "Move.h"

class Pokemon {
  public:
    const char* name;

    int maxHP;
    int currentHP;
    int energy;

    Move moves[3];

    Pokemon(const char* name, int hp);

    virtual void attack(int moveIndex, Pokemon &target);
    virtual void playAnimation(int animationID);

    void gainEnergy(int amount);
};

#endif


---

📄 Pokemon.cpp

#include "Pokemon.h"

Pokemon::Pokemon(const char* n, int hp) {
  name = n;
  maxHP = hp;
  currentHP = hp;
  energy = 0;
}

void Pokemon::gainEnergy(int amount) {
  energy += amount;
  if (energy > 10) energy = 10;
}

void Pokemon::attack(int moveIndex, Pokemon &target) {
  Move move = moves[moveIndex];

  if (energy < move.energyCost) return;

  energy -= move.energyCost;

  int damage = move.baseDamage;

  target.currentHP -= damage;
}


